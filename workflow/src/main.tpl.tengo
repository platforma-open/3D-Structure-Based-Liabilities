scoresColumnIds := [
	"mode",
	"extraCysCount", "exposedExtraCysCount",
	"brokenCanonicalDisulfideCount", "missingCanonicalCysCount",
	"surfacedMotifCount", "confidenceGatedMotifCount",
	"motifStructuralRiskScore", "structuralDevelopabilityScore",
	"structuralDevelopabilityRisk", "structuralIntegrityRisk",
	"totalCdrLength", "psh", "pshPatchCount", "ppc", "pnc",
	"sfvcsp", "cdrh3Compactness",
	"totalCdrLengthLowConfidenceResidueFraction",
	"pshLowConfidenceResidueFraction",
	"ppcLowConfidenceResidueFraction",
	"pncLowConfidenceResidueFraction",
	"sfvcspLowConfidenceResidueFraction",
	"cdrh3CompactnessLowConfidenceResidueFraction",
	"totalCdrLengthFlag", "pshFlag", "ppcFlag", "pncFlag",
	"sfvcspFlag", "cdrh3CompactnessFlag"
]

wf.body(func(args) {
	// Spec R43 — every emitted PColumn carries `domain.pl7.app/blockId`
	// scoped to this block instance so downstream blocks can disambiguate
	// outputs from multiple instances of the same block kind.
	blockId := wf.blockId().getDataAsJson()

	pdbImport := file.importFile(args.pdb)

	cmd := exec.builder().
		software(liabilitiesSw).
		mem("2GiB").
		cpu(1).
		printErrStreamToStdout().
		addFile("input.pdb", pdbImport.file).
		arg("--pdb").arg("input.pdb").
		arg("--output").arg("liabilities.json").
		arg("--motifs-pframe-dir").arg(motifsFrameName).
		arg("--cysteines-pframe-dir").arg(cysFrameName).
		arg("--scores-pframe-dir").arg(scoresFrameName)

	if !is_undefined(args.numberingScheme) && args.numberingScheme != "" {
		cmd = cmd.arg("--numbering-scheme").arg(args.numberingScheme)
	}
	if !is_undefined(args.heavyChainId) && args.heavyChainId != "" {
		cmd = cmd.arg("--chain-h").arg(args.heavyChainId)
	}
	if !is_undefined(args.lightChainId) && args.lightChainId != "" {
		cmd = cmd.arg("--chain-l").arg(args.lightChainId)
	}

	result := cmd.
		saveFile("liabilities.json").
		processWorkdir("motifsResult", ptImportDirTpl, func() {
			m := {}
			m[motifsFrameName] = motifColumnIds
			return m
		}()).
		processWorkdir("cysResult", ptImportDirTpl, func() {
			m := {}
			m[cysFrameName] = cysColumnIds
			return m
		}()).
		processWorkdir("scoresResult", ptImportDirTpl, func() {
			m := {}
			m[scoresFrameName] = scoresColumnIds
			return m
		}()).
		run()

	motifData := result.getProcessorResult("motifsResult")
	cysData := result.getProcessorResult("cysResult")
	scoresData := result.getProcessorResult("scoresResult")

	motifsPfBuilder := pframes.pFrameBuilder()
	for colId in motifColumnIds {
		spec := {
			kind: "PColumn",
			valueType: motifColumnSpecs[colId].valueType,
			name: motifColumnSpecs[colId].name,
			domain: { "pl7.app/blockId": blockId },
			annotations: motifColumnSpecs[colId].annotations,
			axesSpec: motifAxesSpec
		}
		columnRef := ptUtil.makeFrameColumnRef(motifsFrameName, colId)
		motifsPfBuilder.add(colId, spec, motifData.getFutureInputField(columnRef))
	}
	motifsPf := motifsPfBuilder.build()

	cysPfBuilder := pframes.pFrameBuilder()
	for colId in cysColumnIds {
		spec := {
			kind: "PColumn",
			valueType: cysColumnSpecs[colId].valueType,
			name: cysColumnSpecs[colId].name,
			domain: { "pl7.app/blockId": blockId },
			annotations: cysColumnSpecs[colId].annotations,
			axesSpec: cysAxesSpec
		}
		columnRef := ptUtil.makeFrameColumnRef(cysFrameName, colId)
		cysPfBuilder.add(colId, spec, cysData.getFutureInputField(columnRef))
	}
	cysPf := cysPfBuilder.build()

	scoresPfBuilder := pframes.pFrameBuilder()
	for colId in scoresColumnIds {
		spec := {
			kind: "PColumn",
			valueType: scoresColumnSpecs[colId].valueType,
			name: scoresColumnSpecs[colId].name,
			domain: { "pl7.app/blockId": blockId },
			annotations: scoresColumnSpecs[colId].annotations,
			axesSpec: scoresAxesSpec
		}
		columnRef := ptUtil.makeFrameColumnRef(scoresFrameName, colId)
		scoresPfBuilder.add(colId, spec, scoresData.getFutureInputField(columnRef))
	}
	scoresPf := scoresPfBuilder.build()

	return {
		outputs: {
			liabilitiesJson: file.exportFile(result.getFile("liabilities.json")),
			motifsData: pframes.exportFrame(motifsPf),
			cysData: pframes.exportFrame(cysPf),
			scoresData: pframes.exportFrame(scoresPf),
			pdbImportHandle: pdbImport.handle
		},
		exports: {}
	}
})
