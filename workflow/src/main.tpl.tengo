// Spec R38 scalar-per-structure PFrame. `structureId` is a placeholder
// axis until upstream provides clonotype keys via PrimaryRef (R1-R6).
// R23 summary counts + R38 motif scalars + R24-R30 surface metrics +
// R36 low-conf fractions + R39 threshold flags all ride here.
// R40: only the *Flag columns carry `pl7.app/isScore: "true"`.
scoresAxesSpec := [
	{
		name: "pl7.app/structure/id",
		type: "String",
		annotations: { "pl7.app/label": "Structure" }
	}
]

