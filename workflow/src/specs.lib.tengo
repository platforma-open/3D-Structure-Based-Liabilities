		"pl7.app/liabilities/pncFlag", "PNC flag", "950"),
	sfvcspFlag: flagColumnSpec(
		"pl7.app/liabilities/sfvcspFlag", "SFvCSP flag", "940"),
	cdrh3CompactnessFlag: flagColumnSpec(
		"pl7.app/liabilities/cdrh3CompactnessFlag", "CDRH3 compactness flag", "940")
}

scoresColumnIds := [
	"mode",
	"extraCysCount", "exposedExtraCysCount",
	"brokenCanonicalDisulfideCount", "missingCanonicalCysCount",
	"surfacedMotifCount", "confidenceGatedMotifCount",
	"motifStructuralRiskScore", "structuralDevelopabilityScore",
	"structuralDevelopabilityRisk", "structuralIntegrityRisk",
	"totalCdrLength", "psh", "pshPatchCount", "ppc", "pnc",
	"sfvcsp", "cdrh3Compactness",
	"totalCdrLengthLowConfidenceResidueFraction",
	"pshLowConfidenceResidueFraction",
	"ppcLowConfidenceResidueFraction",
	"pncLowConfidenceResidueFraction",
	"sfvcspLowConfidenceResidueFraction",
	"cdrh3CompactnessLowConfidenceResidueFraction",
	"totalCdrLengthFlag", "pshFlag", "ppcFlag", "pncFlag",
	"sfvcspFlag", "cdrh3CompactnessFlag"
]

// ──────────────── Xsv settings (PrimaryRef path) ────────────────
// `pframes.processColumn` runs `xsv.importFile` over each per-clonotype
// parquet file. Settings declare how to read the parquet:
//   - `axes` maps parquet column names → axis specs (each entry's `column`
//     is the parquet column name).
//   - `columns` maps parquet column names → PColumn specs.
// Parquet columns not listed here are silently dropped by pfconv.
// processColumn prepends `pl7.app/vdj/scClonotypeKey` from the input
// column to every output PColumn (Spec R1-R6 , the real per-clonotype axis).

// Maps parquet column name → axis spec, for the motif/cys axes.
motifAxisParquetMapping := [
	{ parquet: "chainId", spec: motifAxesSpec[0] },
	{ parquet: "resSeq", spec: motifAxesSpec[1] },
	{ parquet: "iCode", spec: motifAxesSpec[2] },
	// Python writes the motif type into the "type" parquet column; the
	// PColumn axis name is `pl7.app/liabilities/motifType`.
	{ parquet: "type", spec: motifAxesSpec[3] }
]

cysAxisParquetMapping := [
	{ parquet: "chainId", spec: cysAxesSpec[0] },
	{ parquet: "resSeq", spec: cysAxesSpec[1] },
	{ parquet: "iCode", spec: cysAxesSpec[2] }
]

// Build the Xsv column[] entries for a given frame, injecting
// `pl7.app/blockId` into each column spec's domain so R43 traceability
// reaches downstream blocks.
buildXsvColumns := func(columnIds, columnSpecs, blockId) {
	out := []
	for id in columnIds {
		raw := columnSpecs[id]
		out = append(out, {
			column: id,
			id: id,
			spec: {
				valueType: raw.valueType,
				name: raw.name,
				domain: { "pl7.app/blockId": blockId },
				annotations: raw.annotations
			}
		})
	}
	return out
}

xsvAxesFromMapping := func(mapping) {
	out := []
	for entry in mapping {
		out = append(out, { column: entry.parquet, spec: entry.spec })
	}
	return out
}

buildMotifsXsvSettings := func(blockId) {
	return {
		axes: xsvAxesFromMapping(motifAxisParquetMapping),
		columns: buildXsvColumns(motifColumnIds, motifColumnSpecs, blockId),
		storageFormat: "Parquet"
	}
}

buildCysXsvSettings := func(blockId) {
	return {
		axes: xsvAxesFromMapping(cysAxisParquetMapping),
		columns: buildXsvColumns(cysColumnIds, cysColumnSpecs, blockId),
		storageFormat: "Parquet"
	}
}

// Scores frame, single-shot path. Python emits a TSV with `sampleId`
// and `clonotypeKey` as the first two columns; `xsv.importFile` maps
// them to the upstream PDB column's axes (`pl7.app/sampleId` and
// `pl7.app/vdj/scClonotypeKey`, per R2). The axis specs are inherited
// from the resolved PDB column at workflow time, so this helper takes
// them as an argument instead of declaring them locally.
buildScoresXsvSettings := func(blockId, sampleIdAxisSpec, scClonotypeAxisSpec) {
	return {
		axes: [
			{ column: "sampleId", spec: sampleIdAxisSpec },
			{ column: "clonotypeKey", spec: scClonotypeAxisSpec }
		],
		columns: buildXsvColumns(scoresColumnIds, scoresColumnSpecs, blockId),
		storageFormat: "Parquet"
	}
}

export ll.toStrict({
	motifAxesSpec: motifAxesSpec,
	motifColumnSpecs: motifColumnSpecs,
	motifColumnIds: motifColumnIds,
	cysAxesSpec: cysAxesSpec,
	cysColumnSpecs: cysColumnSpecs,
	cysColumnIds: cysColumnIds,
	scoresAxesSpec: scoresAxesSpec,
	scoresColumnSpecs: scoresColumnSpecs,
	scoresColumnIds: scoresColumnIds,
	buildMotifsXsvSettings: buildMotifsXsvSettings,
	buildCysXsvSettings: buildCysXsvSettings,
	buildScoresXsvSettings: buildScoresXsvSettings
})
