// Workdir directory names that Python's pframe_writer.py emits parquet into.
motifsFrameName := "motifs_pf"
cysFrameName := "cysteines_pf"
scoresFrameName := "scores_pf"

// ──────────────── Xsv settings (PrimaryRef path) ────────────────
// `pframes.processColumn` runs `xsv.importFile` over each per-clonotype
// parquet file. Settings declare how to read the parquet:
//   - `axes` maps parquet column names → axis specs (each entry's `column`
//     is the parquet column name).
//   - `columns` maps parquet column names → PColumn specs.
// Parquet columns not listed here are silently dropped by pfconv. That's how
// the scores frame omits the python-side `structureId="static"` placeholder
// — processColumn prepends `pl7.app/vdj/scClonotypeKey` from the input column,
// which replaces the placeholder per Spec R1-R6.

// Maps parquet column name → axis spec, for the motif/cys axes.
motifAxisParquetMapping := [
	{ parquet: "chainId", spec: motifAxesSpec[0] },
	{ parquet: "resSeq", spec: motifAxesSpec[1] },
	{ parquet: "iCode", spec: motifAxesSpec[2] },
	// Python writes the motif type into the "type" parquet column; the
	// PColumn axis name is `pl7.app/liabilities/motifType`.
	{ parquet: "type", spec: motifAxesSpec[3] }
]

cysAxisParquetMapping := [
	{ parquet: "chainId", spec: cysAxesSpec[0] },
	{ parquet: "resSeq", spec: cysAxesSpec[1] },
	{ parquet: "iCode", spec: cysAxesSpec[2] }
]

// Build the Xsv column[] entries for a given frame, injecting
// `pl7.app/blockId` into each column spec's domain so R43 traceability is
// preserved on the PrimaryRef path (same as the legacy path).
buildXsvColumns := func(columnIds, columnSpecs, blockId) {
	out := []
	for id in columnIds {
		raw := columnSpecs[id]
		out = append(out, {
			column: id,
			id: id,
			spec: {
				valueType: raw.valueType,
				name: raw.name,
				domain: { "pl7.app/blockId": blockId },
				annotations: raw.annotations
			}
		})
	}
	return out
}

xsvAxesFromMapping := func(mapping) {
	out := []
	for entry in mapping {
		out = append(out, { column: entry.parquet, spec: entry.spec })
	}
	return out
}

buildMotifsXsvSettings := func(blockId) {
	return {
		axes: xsvAxesFromMapping(motifAxisParquetMapping),
		columns: buildXsvColumns(motifColumnIds, motifColumnSpecs, blockId),
		storageFormat: "Parquet"
	}
}

buildCysXsvSettings := func(blockId) {
	return {
		axes: xsvAxesFromMapping(cysAxisParquetMapping),
		columns: buildXsvColumns(cysColumnIds, cysColumnSpecs, blockId),
		storageFormat: "Parquet"
	}
}

// Scores frame: parquet carries the legacy `structureId="static"` column;
// `xsv.importFile` requires at least one declared axis, so we keep
// structureId in the Xsv settings even on the PrimaryRef path. The
// resulting PColumn ends up with axes [scClonotypeKey, structureId="static"]
// — slightly redundant but a valid PColumn shape, and it lets the same
// python output feed both the legacy and per-clonotype paths without
// touching the writer.
buildScoresXsvSettings := func(blockId) {
	return {
		axes: [
			{ column: "structureId", spec: scoresAxesSpecLegacy[0] }
		],
		columns: buildXsvColumns(scoresColumnIds, scoresColumnSpecs, blockId),
		storageFormat: "Parquet"
	}
}

export ll.toStrict({
	motifAxesSpec: motifAxesSpec,
	motifColumnSpecs: motifColumnSpecs,
	motifColumnIds: motifColumnIds,
	cysAxesSpec: cysAxesSpec,
	cysColumnSpecs: cysColumnSpecs,
	cysColumnIds: cysColumnIds,
	scoresAxesSpecLegacy: scoresAxesSpecLegacy,
	scoresAxesSpecPerClonotype: scoresAxesSpecPerClonotype,
	scoresColumnSpecs: scoresColumnSpecs,
	scoresColumnIds: scoresColumnIds,
	motifsFrameName: motifsFrameName,
	cysFrameName: cysFrameName,
	scoresFrameName: scoresFrameName,
	buildMotifsXsvSettings: buildMotifsXsvSettings,
	buildCysXsvSettings: buildCysXsvSettings,
	buildScoresXsvSettings: buildScoresXsvSettings
})
