// ──────────────── Scores PFrame ────────────────
// `pt.saveFrameDirect` hard-requires `len(axes) > 0` (assertion at
// `@platforma-sdk/workflow-tengo:pt.util:40`), even when processColumn
// already prepends the upstream PDB column's `[sampleId, scClonotypeKey]`
// to every output. We keep a constant-valued `structureId="static"`
// placeholder column to satisfy that assertion, and mark its axis with
// `pl7.app/table/visibility: "hidden"` so `selectDisplayableIndices`
// in `table-source-v2.ts:377` filters it out of the rendered table ,
// no redundant "Structure" cell on every row.
scoresAxesSpec := [
	{
		name: "pl7.app/structure/id",
		type: "String",
		annotations: {
			"pl7.app/label": "Structure",
			"pl7.app/table/visibility": "hidden"
		}
	}
]

