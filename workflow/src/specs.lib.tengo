// ──────────────── Scores PFrame ────────────────
// Legacy path uses scoresAxesSpecLegacy (explicit `structureId="static"`).
// PrimaryRef path uses scoresAxesSpecPerClonotype (empty — `processColumn`
// prepends the upstream `pl7.app/vdj/scClonotypeKey` axis).

// The `structureId` axis is a placeholder forced by `xsv-import-pt`'s
// "at least one axis" requirement. On the PrimaryRef path every row's value
// is "static" — the real per-clonotype axis is the prepended
// `pl7.app/vdj/scClonotypeKey`. Marked `optional` so AG-Grid hides it by
// default; users can re-enable from the Columns toolbar.
scoresAxesSpecLegacy := [
	{
		name: "pl7.app/structure/id",
		type: "String",
		annotations: {
			"pl7.app/label": "Structure",
			"pl7.app/table/visibility": "optional"
		}
	}
]

