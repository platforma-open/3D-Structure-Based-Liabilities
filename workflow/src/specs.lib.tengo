// vim: filetype=go
// PColumn spec setup for the per-clonotype PrimaryRef workflow path.
// Declares axes + column specs for the motifs, cysteines, and scores
// PFrames the Python software produces.
//
// `axesSpec` / `columnSpecs` / `columnIds` mirror the parquet column
// layout `software/src/pframe_writer.py` writes. `pframes.processColumn`
// in main.tpl.tengo prepends a leading `pl7.app/vdj/scClonotypeKey` axis
// to every output PColumn (R1-R6).

ll := import("@platforma-sdk/workflow-tengo:ll")
json := import("json")

// Spec R39 / R54 , Raybould 2019 + Gordon 2025 amber/red threshold values.
// Encoded as `pl7.app/graph/thresholds` annotations on the metric columns so
// GraphMaker can draw them as dashed lines on histograms / scatter plots.
// Today the histogram code path in `@milaboratories/graph-maker` doesn't yet
// honor this annotation (only the scatter path does); the annotation is still
// emitted so the lines render automatically when histogram support lands.
thresholdsFor := func(colName, values) {
	entries := []
	for v in values {
		entries = append(entries, {
			columnId: { valueType: "Double", name: colName },
			value: v
		})
	}
	// PColumn annotations are strings. `json.encode` in Tengo returns bytes;
	// the validator rejects bytes for a `string`-typed annotation slot. Wrap
	// in `string(...)` so the spec round-trips as plain JSON text.
	return string(json.encode(entries))
}

// ──────────── PColumn spec helpers (scores frame) ────────────
//
// The scores PFrame carries ~25 columns that fall into three repetitive
// shapes. Each helper below collapses one of those shapes into a single
// call site so the column → label → threshold mapping is reviewable as a
// table instead of buried in 10 lines of dict-per-column boilerplate.
// New columns added through these helpers automatically inherit the spec's
// visibility / format / isScore conventions.

// Raw Double surface metric (PSH, PPC, PNC, SFvCSP, CDRH3 compactness).
// Always hidden by default per R51 ("show all" reveals); carries the
// Raybould 2019 / Gordon 2025 amber/red threshold values as a graph
// annotation (R39 / R54).
metricColumnSpec := func(name, label, format, orderPriority, thresholdValues) {
	return {
		valueType: "Double",
		name: name,
		annotations: {
			"pl7.app/label": label,
			"pl7.app/format": format,
			"pl7.app/table/visibility": "optional",
			"pl7.app/table/orderPriority": orderPriority,
			"pl7.app/graph/thresholds": thresholdsFor(name, thresholdValues)
		}
	}
}

// R36 per-metric low-confidence-residue fraction. Always Double, always
// hidden by default, never carries threshold annotations (fractions don't
// have Raybould bands).
lowConfFractionSpec := func(name, label, orderPriority) {
	return {
		valueType: "Double",
		name: name,
		annotations: {
			"pl7.app/label": label,
			"pl7.app/format": ".2f",
			"pl7.app/table/visibility": "optional",
			"pl7.app/table/orderPriority": orderPriority
		}
	}
}

// R39 three-band flag column. Always String ("green" / "amber" / "red" /
// "-" sentinel when inapplicable), always visible by default per R51,
// always carries the apo-vs-bound tooltip and isScore so PlAgDataTable
// styles the cell. Identical shape per flag; only label / orderPriority
// differ.
_FLAG_DESCRIPTION := "Flag reflects predicted apo conformation; bound conformation may differ."
flagColumnSpec := func(name, label, orderPriority) {
	return {
		valueType: "String",
		name: name,
		annotations: {
			"pl7.app/label": label,
			"pl7.app/isScore": "true",
			"pl7.app/description": _FLAG_DESCRIPTION,
			"pl7.app/table/visibility": "default",
			"pl7.app/table/orderPriority": orderPriority
		}
	}
}

