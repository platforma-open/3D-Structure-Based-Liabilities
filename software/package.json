{
  "name": "@platforma-open/milabs.3d-structure-based-liabilities.software",
  "version": "0.1.0",
  "scripts": {
    "build": "pl-pkg build",
    "prepublishOnly": "pl-pkg prepublish",
    "do-pack": "shx rm -f *.tgz && pl-pkg build && pnpm pack && shx mv platforma-open*.tgz package.tgz"
  },
  "files": [
    "./dist/**/*"
  ],
  "dependencies": {},
  "devDependencies": {
    "@platforma-sdk/package-builder": "catalog:",
    "@platforma-open/milaboratories.runenv-python-3": "catalog:",
    "shx": "catalog:"
  },
  "block-software": {
    "entrypoints": {
      "liabilities": {
        "docker": {
          "artifact": {
            "type": "docker",
            "context": "./src",
            "dockerfile": "Dockerfile"
          },
          "cmd": [
            "python",
            "/app/main.py"
          ]
        },
        "binary": {
          "artifact": {
            "type": "python",
            "registry": "platforma-open",
            "environment": "@platforma-open/milaboratories.runenv-python-3:3.12.10",
            "dependencies": {
              "toolset": "pip",
              "requirements": "requirements.txt"
            },
            "root": "./src"
          },
          "cmd": [
            "python",
            "{pkg}/main.py"
          ]
        }
      }
    }
  }
}
